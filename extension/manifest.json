{
  "manifest_version": 3,
  "name": "Sayane",
  "version": "0.3.5",
  "description": "Capture web context and insert Sayane context packets into LLM UIs.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*"
  ],
  "action": {
    "default_title": "Sayane",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
