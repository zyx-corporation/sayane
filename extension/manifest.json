{
  "manifest_version": 3,
  "name": "Sayane",
  "version": "0.3.8",
  "description": "Capture web context and insert Sayane context packets into LLM UIs.",
  "permissions": ["storage", "activeTab", "scripting", "clipboardRead"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*"
  ],
  "action": {
    "default_title": "Sayane",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": ["dist/content.bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
