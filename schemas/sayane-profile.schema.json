{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sayane.dev/schemas/sayane-profile.schema.json",
  "title": "SayaneProfile",
  "description": "Structured persona and context profile independent of any LLM runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "kind",
    "identity",
    "voice",
    "values",
    "policy",
    "context_index",
    "lineage"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "kind": {
      "type": "string",
      "const": "SayaneProfile"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "preferred_name": { "type": "string" },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_language": { "type": "string" },
        "tone": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "core": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "knowledge": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "concepts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "response": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "avoid": {
              "type": "array",
              "items": { "type": "string" }
            },
            "prefer": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "context_index": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entrypoint": { "type": "string" },
        "handoff": { "type": "string" },
        "entries": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "updated_at"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
