{
  "name": "sayane-extension",
  "version": "0.3.0",
  "private": true,
  "description": "Sayane Chrome Extension — capture and insert context (Phase 3)",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test:e2e:real": "playwright test -c e2e/playwright.real.config.ts",
    "test:e2e:real:chatgpt": "playwright test -c e2e/playwright.real.config.ts chatgpt.real.spec.ts",
    "test:e2e:real:claude": "playwright test -c e2e/playwright.real.config.ts claude.real.spec.ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/chrome": "^0.0.287",
    "typescript": "^5.7.3"
  }
}
